{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yazd",
  "version": "0.1.0",
  "identifier": "com.kkarimi.yazd",
  "build": {
    "beforeBuildCommand": "npm run app:build",
    "beforeDevCommand": "npm run app:dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist-app"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Yazd",
        "width": 1320,
        "height": 860,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
